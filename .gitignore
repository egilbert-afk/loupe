# =============================================================================
# Jewelry Box — .gitignore
# Node.js + Next.js + Supabase
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — never commit these under any circumstances
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# -----------------------------------------------------------------------------
# Node / Next.js
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
build/
dist/

.next/cache/

# Vercel
.vercel/

# npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
.supabase/
supabase/.temp/

# -----------------------------------------------------------------------------
# Uploaded item photos and appraisal documents — never commit user content
# -----------------------------------------------------------------------------
scripts/uploads/
*.heic

# -----------------------------------------------------------------------------
# OS / editor junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
